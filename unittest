import unittest
from gui import SolitaireGame
import tkinter as tk

class TestSolitaireLogic(unittest.TestCase):
    def setUp(self):
        self.root = tk.Tk()
        self.game = SolitaireGame(self.root)

    def test_english_board_dimensions(self):
        """Verify the English board is a 7x7 grid."""
        layout = self.game.createEnglishBoard()
        self.assertEqual(len(layout), 7)
        self.assertEqual(len(layout[0]), 7)

    def test_english_board_initial_hole(self):
        """Verify the center of the English board (3,3) is an empty hole (value 2)."""
        layout = self.game.createEnglishBoard()
        # Row 3, Column 3 should be 2 (empty hole)
        self.assertEqual(layout[3][3], 2)

    def tearDown(self):
        self.root.destroy()

if __name__ == '__main__':
    unittest.main()
