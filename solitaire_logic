class SolitaireLogic:
    """
    Handles the game rules, board generation, and state validation.
    Separated from the GUI class to follow MVC principles.
    """
    def __init__(self):
        self.board = []

    def get_layout(self, board_type, size):
        """Returns the appropriate board layout based on type and size."""
        if board_type == 'english':
            return self.create_english_board(size)
        elif board_type == 'diamond':
            return self.create_diamond_board(size)
        elif board_type == 'hexagon':
            # European/Hexagon is typically fixed or follows specific scaling
            return self.create_european_board(size)
        return []

    def create_english_board(self, size=7):
        """
        Generates an English board (cross shape).
        Standard is 7x7 with 3x3 arms.
        """
        board = []
        # Arm thickness is roughly 1/3 of the size
        arm = size // 3
        for row in range(size):
            current_row = []
            for col in range(size):
                # Identify the four corner 'invalid' areas
                is_corner = (row < arm or row >= size - arm) and \
                            (col < arm or col >= size - arm)
                
                if is_corner:
                    current_row.append(0)  # Invalid space
                elif row == size // 2 and col == size // 2:
                    current_row.append(2)  # Initial empty hole
                else:
                    current_row.append(1)  # Peg
            board.append(current_row)
        return board

    def create_diamond_board(self, size=9):
        """
        Generates a Diamond-shaped board using Manhattan distance.
        """
        board = []
        center = size // 2
        for row in range(size):
            current_row = []
            for col in range(size):
                # Distance from center determines if it's within the diamond
                distance = abs(row - center) + abs(col - center)
                if distance > center:
                    current_row.append(0)  # Invalid
                elif row == center and col == center:
                    current_row.append(2)  # Initial empty hole
                else:
                    current_row.append(1)  # Peg
            board.append(current_row)
        return board

